DISCORD_TOKEN=
WATCH_CHANNEL_ID=
# Private Discord channel used for JSON persistence snapshots AND debug log uploads
# (recommended: a locked channel like #warbot-storage)
DISCORD_STORAGE_CHANNEL_ID=
OPENAI_API_KEY=
# Domyślny model jest ustawiony na gpt-4o (lepsza jakość kosztem ceny).
# Jeśli chcesz taniej, ustaw np. gpt-4o-mini.
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_SECONDS=90
# Chat ranking OCR: slicing/overlap mode is used automatically when validation fails.
# Primary number of slices (cost vs robustness): 4 is a good default.
OPENAI_CHAT_SLICES=4
# Fallback number of slices if OCR is still invalid: 6 is safer but costs more.
OPENAI_CHAT_SLICES_FALLBACK=6

# Logging
# Console log level (INFO recommended). File log is always created (default log.txt).
LOG_LEVEL=INFO
LOG_FILE=log.txt
LOG_FILE_LEVEL=DEBUG
LOG_MAX_BYTES=5000000
LOG_BACKUPS=2

# Render Free has no Shell, so you can't easily download LOG_FILE.
# If enabled, the bot will attach a per-run debug log as a .txt file on Discord.
SEND_LOG_TO_DISCORD=1
# If enabled, only send the log when at least one player remained UNKNOWN (or on exceptions).
# Recommended on free hosting tiers.
SEND_LOG_ONLY_ON_UNKNOWN=1
# Deprecated (backwards compatibility): older versions used WARN condition.
SEND_LOG_ONLY_ON_WARN=0
# Safety cap for the uploaded log size (bytes). If exceeded, only the last chunk is uploaded.
DISCORD_LOG_MAX_BYTES=1500000

# HELP command: auto-delete bot's help messages after N seconds (default 30)
HELP_AUTO_DELETE_SEC=30

# LISTWAR: send a short "processing started" message (deleted automatically at the end)
LISTWAR_PROGRESS_ENABLED=1
ROSTER_PATH=roster.json
# Optional: additional roster entries managed by the bot via reply command `ADDROSTER <nick>`.
ROSTER_OVERRIDES_PATH=roster_overrides.json
ALIASES_PATH=aliases.json

# Cost optimization: try cheap row-crop repair for suspicious nicknames before full slicing.
CHAT_ROW_REPAIR=1
# Skip row-repair if too many ranks are suspicious (then go straight to slicing).
CHAT_ROW_REPAIR_MAX_RANKS=5
# Max number of cropped windows (clusters) to try per run.
CHAT_ROW_REPAIR_MAX_CLUSTERS=3
# Fraction of the preprocessed ROI treated as header above the first rank row.
CHAT_ROW_REPAIR_HEADER_RATIO=0.12
# How many lines above/below the suspicious ranks to include in the crop (context for OCR).
CHAT_ROW_REPAIR_PAD_LINES=1.35
